<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>ShiroBot.AvaloniaSdk</PackageId>
        <Version>0.1.0</Version>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\ShiroBot.SDK\ShiroBot.SDK.csproj" />
    </ItemGroup>

    <!--
        Avalonia 程序集只用于编译期类型签名；运行期由 ShiroBot.AvaloniaIntegration 在宿主 Default ALC 中提供。
        因此 ExcludeAssets="runtime"，让消费此 SDK 的 feature plugin 不会把 Avalonia.dll 复制到自己的输出目录。
    -->
    <ItemGroup>
        <PackageReference Include="Avalonia" Version="12.0.3">
            <ExcludeAssets>runtime</ExcludeAssets>
            <PrivateAssets>none</PrivateAssets>
        </PackageReference>
    </ItemGroup>

</Project>
