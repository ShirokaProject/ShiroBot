<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ShiroBot.AvaloniaDemoPlugin.ViewModels"
             x:Class="ShiroBot.AvaloniaDemoPlugin.Views.DescriptionCard"
             x:DataType="vm:DescriptionCardViewModel"
             MinWidth="700" MinHeight="350">

    <Design.DataContext>
        <vm:DescriptionCardViewModel/>
    </Design.DataContext>

    <Border
        Background="#FFFFFF"
        CornerRadius="10"
        BorderBrush="#D0D7DE"
        BorderThickness="1"
        ClipToBounds="True">

    <Grid RowDefinitions="*, Auto, Auto, 6">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="32,32,32,24">

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                <TextBlock Text="{Binding OwnerDisplay}"
                           Margin="0,0,0,16"
                           FontSize="24"
                           Foreground="#57606A"
                           FontWeight="Light"
                           TextTrimming="None"
                           MaxLines="1"/>

                <TextBlock Text="{Binding Repository}"
                           FontSize="48"
                           Foreground="#24292F"
                           FontWeight="Bold"
                           Margin="0,-8,0,16"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Left"
                           Width="450"
                           MaxLines="2"
                           LineHeight="52"/>

                <TextBlock Text="{Binding Description}"
                           HorizontalAlignment="Left"
                           Width="430"
                           FontSize="18"
                           Foreground="#57606A"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="4"
                           LineHeight="26"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Width="140"
                    Height="140"
                    CornerRadius="16"
                    VerticalAlignment="Center"
                    ClipToBounds="True">
                <Border.Background>
                    <!-- 用深色星空渐变模拟一下你图里的背景 -->
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#161b22" Offset="0"/>
                        <GradientStop Color="#30244d" Offset="0.5"/>
                        <GradientStop Color="#1e2d40" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Image Source="{Binding Avatar}"
                           IsVisible="{Binding HasAvatar}"
                           Stretch="UniformToFill"/>
                    <TextBlock Text="{Binding OwnerInitial}"
                               IsVisible="{Binding HasNoAvatar}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="64"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 下半部分：统计数据区 -->
        <Grid Grid.Row="1" Margin="32,0,32,32" ColumnDefinitions="*,Auto">

            <!-- 左侧5个数据项 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="40" VerticalAlignment="Bottom">

                <!-- Contributors -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" Fill="#57606A" Width="16" Height="16" Stretch="Uniform"/>
                        <TextBlock Text="{Binding Contributors}" FontSize="18" FontWeight="SemiBold" Foreground="#24292F"/>
                    </StackPanel>
                    <TextBlock Text="Contributors" FontSize="14" Foreground="#57606A" Margin="24,4,0,0"/>
                </StackPanel>

                <!-- Issues -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Data="M8 1.5a6.5 6.5 0 100 13 6.5 6.5 0 000-13zM0 8a8 8 0 1116 0A8 8 0 010 8zm9 3a1 1 0 11-2 0 1 1 0 012 0zm-.25-6.25a.75.75 0 00-1.5 0v3.5a.75.75 0 001.5 0v-3.5z" Fill="#57606A" Width="16" Height="16" Stretch="Uniform"/>
                        <TextBlock Text="{Binding Issues}" FontSize="18" FontWeight="SemiBold" Foreground="#24292F"/>
                    </StackPanel>
                    <TextBlock Text="Issues" FontSize="14" Foreground="#57606A" Margin="24,4,0,0"/>
                </StackPanel>

                <!-- Discussions -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Data="M1.75 1h12.5c.966 0 1.75.784 1.75 1.75v8.5A1.75 1.75 0 0114.25 13H8.061l-2.574 2.573A1.458 1.458 0 013 14.543V13H1.75A1.75 1.75 0 010 11.25v-8.5C0 1.784.784 1 1.75 1zM1.5 2.75v8.5c0 .138.112.25.25.25h12.5a.25.25 0 00.25-.25v-8.5a.25.25 0 00-.25-.25H1.75a.25.25 0 00-.25.25z" Fill="#57606A" Width="16" Height="16" Stretch="Uniform"/>
                        <TextBlock Text="{Binding Discussions}" FontSize="18" FontWeight="SemiBold" Foreground="#24292F"/>
                    </StackPanel>
                    <TextBlock Text="Discussions" FontSize="14" Foreground="#57606A" Margin="24,4,0,0"/>
                </StackPanel>

                <!-- Stars -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Data="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.751.751 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z" Fill="#57606A" Width="16" Height="16" Stretch="Uniform"/>
                        <TextBlock Text="{Binding Stars}" FontSize="18" FontWeight="SemiBold" Foreground="#24292F"/>
                    </StackPanel>
                    <TextBlock Text="Stars" FontSize="14" Foreground="#57606A" Margin="24,4,0,0"/>
                </StackPanel>

                <!-- Forks -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Data="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75v-.878a2.25 2.25 0 111.5 0v.878a2.25 2.25 0 01-2.25 2.25h-1.5v2.128a2.251 2.251 0 11-1.5 0V8.5h-1.5A2.25 2.25 0 013 6.25v-.878a2.25 2.25 0 111.5 0ZM5 3.25a.75.75 0 10-1.5 0 .75.75 0 001.5 0Zm6.75.75a.75.75 0 100-1.5.75.75 0 000 1.5Zm-3 8.75a.75.75 0 10-1.5 0 .75.75 0 001.5 0Z" Fill="#57606A" Width="16" Height="16" Stretch="Uniform"/>
                        <TextBlock Text="{Binding Forks}" FontSize="18" FontWeight="SemiBold" Foreground="#24292F"/>
                    </StackPanel>
                    <TextBlock Text="Forks" FontSize="14" Foreground="#57606A" Margin="24,4,0,0"/>
                </StackPanel>

            </StackPanel>

            <!-- 右侧 GitHub Logo (用圆形和简单路径近似代替，建议自己换标准图标) -->
            <Path Grid.Column="1" VerticalAlignment="Bottom" Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" Fill="#8C959F" Width="28" Height="28" Stretch="Uniform"/>
        </Grid>

        <!-- 最底部的语言颜色条 (按比例分配宽度) -->
        <Grid Row="3" ColumnDefinitions="Auto,*" Height="40">
            <Border Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="8,0,5,15"
                        >
                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                    <Ellipse Grid.Column="0" Width="10" Height="10"
                             Margin="0 0 6 0"
                             VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding Language1Color}"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <TextBlock Grid.Column="1"
                               Foreground="#57606A"
                               Text="{Binding PrimaryLanguage}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Column="1" Height="10"
                  Margin="0 0 0 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Language1Width}"/>
                    <ColumnDefinition Width="{Binding Language2Width}"/>
                    <ColumnDefinition Width="{Binding Language3Width}"/>
                    <ColumnDefinition Width="{Binding Language4Width}"/>
                    <ColumnDefinition Width="{Binding Language5Width}"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8,0,0,8">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding Language1Color}"/>
                    </Border.Background>
                </Border>
                <Rectangle Grid.Column="1">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding Language2Color}"/>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Grid.Column="2">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding Language3Color}"/>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Grid.Column="3">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding Language4Color}"/>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Grid.Column="4">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="{Binding Language5Color}"/>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
        </Grid>

    </Grid>
</Border>
</UserControl>
